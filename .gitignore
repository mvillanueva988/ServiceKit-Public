# ==========================================
# PC Optimizacion Toolkit
# ==========================================

# Logs y salidas de scripts
*.log
*.csv
*.txt

# Datos serializados de powershell
*.clixml

# Configuraciones locales de VS Code
.vscode/

# Variables de entorno o secretos
*.env

# Ejecutables y binarios de herramientas (ver tools/manifest.json + Bootstrap-Tools.ps1)
tools/bin/

# Salidas generadas en tiempo de ejecucion (snapshots, driver backups, etc.)
output/
Logs/

# Recetas nombradas del operador (datos de clientes específicos, no publicables).
# Se versionan solo el placeholder y el fixture de smoke; el resto (clientes) NO.
data/profiles/named/*
!data/profiles/named/README.md
!data/profiles/named/_sample.json
!data/profiles/named/gaming-template.json

# Build artifacts de Release.ps1
dist/
dist/*.zip
dist/*.sha256

# Artifacts de trabajo interno (no publicar en repo toolkit)
.gsd/
.github/
*.code-workspace
GSD-STYLE.md
_local-dev/
# Worktrees auxiliares creadas por tooling local (nunca publicar)
.clone/

# Handoffs / contratos de implementacion (scratch, no publicar en repo toolkit)
HANDOFF_*.md

# Doc interna de Claude Code — NO publicar en el repo publico.
# Claude Code la lee de disco igual (gitignore no afecta el auto-load).
# Privada desde 2026-06-26 por decision de Mateo.
CLAUDE.md

# Catalogo de referencia de OOSU (fuente para regenerar / diff cross-OS;
# la app NO lo consume: las recetas usan basic/medium/multimedia/aggressive.cfg)
data/oosu10-profiles/_*.cfg

# ==========================================
# GSD Framework / Copilot AI
# ==========================================

node_modules/
.DS_Store
TO-DOS.md
/research.claude/
commands.html
.claude/

# Build artifacts (committed to npm, not git)
hooks/dist/

# Animation assets
animation/
*.gif

_local-dev/
