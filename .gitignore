# ==========================================
# PC Optimizacion Toolkit
# ==========================================

# Logs y salidas de scripts
*.log
*.csv
*.txt

# Datos serializados de powershell
*.clixml

# Configuraciones locales de VS Code
.vscode/

# Variables de entorno o secretos
*.env

# Ejecutables y binarios de herramientas (ver tools/manifest.json + Bootstrap-Tools.ps1)
tools/bin/

# Salidas generadas en tiempo de ejecucion (snapshots, driver backups, etc.)
output/
Logs/

# Recetas nombradas del operador (datos de clientes específicos, no publicables).
# Se versionan solo el placeholder y el fixture de smoke; el resto (clientes) NO.
data/profiles/named/*
!data/profiles/named/README.md
!data/profiles/named/_sample.json

# Build artifacts de Release.ps1
dist/
dist/*.zip
dist/*.sha256

# Artifacts de trabajo interno (no publicar en repo toolkit)
.gsd/
.github/
*.code-workspace
GSD-STYLE.md
_local-dev/
# ==========================================
# GSD Framework / Copilot AI
# ==========================================

node_modules/
.DS_Store
TO-DOS.md
CLAUDE.md
/research.claude/
commands.html
.claude/

# Build artifacts (committed to npm, not git)
hooks/dist/

# Animation assets
animation/
*.gif
