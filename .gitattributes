tests/stage4-sandbox.wsb export-ignore
tests/postqueue-validate.ps1 export-ignore
tests/postqueue-sandbox-launcher.ps1 export-ignore
tests/postqueue-sandbox.wsb export-ignore

# Glob defensivo: TODO rig (presente y futuro) queda fuera del ZIP sin tener
# que enumerarlo a mano. La enumeracion explicita de arriba se mantiene; estos
# patrones cubren lo que se olvide (ej: tests/uninstall-* se filtro a v2.0.0
# porque no estaba enumerado). No matchea tests/smoke.ps1 (ese si viaja).
tests/*-validate.ps1 export-ignore
tests/*-sandbox-launcher.ps1 export-ignore
tests/*-sandbox.wsb export-ignore
tests/*-sandbox-test.wsb export-ignore
tests/*-harness.ps1 export-ignore

# Directorio de trabajo interno (defensivo aunque ya gitignored)
_local-dev/ export-ignore
