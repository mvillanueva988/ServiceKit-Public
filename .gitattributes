# export-ignore: archivos trackeados pero no destinados al ZIP publico.
# git archive honra esta lista; lo que NO aparece aqui viaja si esta trackeado.

# Script de release (infra de desarrollo)
Release.ps1 export-ignore

# Changelog interno (no es documentacion de usuario final)
CHANGELOG.md export-ignore

# Rigs de validacion y sandbox (contienen paths absolutos del dev, inservibles para terceros)
