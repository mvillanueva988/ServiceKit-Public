tests/stage2-harness.ps1 export-ignore
tests/stage2-sandbox-launcher.ps1 export-ignore
tests/stage2-sandbox-test.wsb export-ignore
tests/stage3-validate.ps1 export-ignore
tests/stage3-sandbox-launcher.ps1 export-ignore
tests/stage3-sandbox.wsb export-ignore
tests/stage4-validate.ps1 export-ignore
